# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy to .env and fill in real values before running Docker.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Environment ──────────────────────────────────────────────────────────────
# Set to "dev" ONLY on a developer's local machine. When ENV=dev, the API
# accepts bearer tokens prefixed with "mock_" or "test_" without verifying a
# real Clerk JWT (see api/dependencies/auth.py) so local scripts/tests can
# call protected routes without a live Clerk session.
# MUST NEVER be set to "dev" in staging or production - doing so disables
# authentication entirely for anyone who sends a mock_/test_ bearer token.
# Leave unset (or set to "production") everywhere except local dev.
ENV=dev

# ── LLM API Keys ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ── Data sources ─────────────────────────────────────────────────────────────
NEWSAPI_API_KEY=your_newsapi_key_here
ALPHAVANTAGE_API_KEY=your_alphavantage_key_here

# ── PostgreSQL password (docker-compose local `db` service only) ────────────
# Required whenever you run the local `db` container via `docker compose up`.
# This is a placeholder - set it to a real secret before any non-local
# deploy. Never commit the real value.
POSTGRES_PASSWORD=changeme_local_only

# ── Database (Supabase / Neon / RDS / local psql) ────────────────────────────
# Managed Postgres (Supabase/Neon/RDS): use the connection string they gave you.
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
# Local docker-compose `db` service instead: point here and make sure the
# password matches POSTGRES_PASSWORD above exactly, or the api container
# will fail to authenticate against the db container.
# DATABASE_URL=postgresql://postgres:changeme_local_only@db:5432/earnings_agents

# ── Redis (Upstash rediss:// or local redis://) ──────────────────────────────
REDIS_URL=rediss://default:token@host:6379?ssl_cert_reqs=none

# ── Clerk Auth ───────────────────────────────────────────────────────────────
CLERK_JWKS_URL=https://your-clerk-app.clerk.accounts.dev/.well-known/jwks.json
CLERK_API_URL=https://api.clerk.com
# Publishable key (safe to expose, injected at Next.js build time)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...

# ── Frontend URLs (injected at Next.js build time) ──────────────────────────
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
NEXT_PUBLIC_WS_URL=wss://api.yourdomain.com

# Also copy these into web/.env.local for the Next.js dev server:
# NEXT_PUBLIC_API_URL=http://localhost:8000
# NEXT_PUBLIC_WS_URL=ws://localhost:8000
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_ENVIRONMENT=development

# ── CORS (backend) ───────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# In prod: set to your actual domain(s). In dev: http://localhost:3000 is the default.
CORS_ORIGINS=https://app.yourdomain.com,https://yourdomain.com

# ── Agent pipeline flags ─────────────────────────────────────────────────────
LLM_PROVIDER=gemini          # gemini | openai | anthropic | deepseek
USE_REACT=true
USE_REACT_MAX_TURNS=6
ENABLE_REBUTTALS=true

# ── Encryption at rest (BYOK API keys in UserSettings) ───────────────────────
# Fernet key used to encrypt/decrypt user-supplied LLM/data-source API keys
# stored in the user_settings table (see database/crypto.py). Required - the
# app fails fast at startup if this is unset. Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# NEVER rotate this key in place - rotating it makes every previously
# encrypted value undecryptable. Rotating requires a migration that decrypts
# every row with the old key and re-encrypts with the new one.
ENCRYPTION_KEY=your_fernet_key_here

# ── Rate limiting (slowapi) ──────────────────────────────────────────────────
# Applied only to /earnings/predict/{ticker}, /earnings/chat, /earnings/batch.
# Keyed by authenticated user id, falling back to remote IP when unauthenticated.
# Format: "<count>/<second|minute|hour|day>" (see slowapi/limits syntax).
RATE_LIMIT_PREDICT=10/hour
RATE_LIMIT_CHAT=30/hour
RATE_LIMIT_BATCH=3/hour

# Daily quotas stacked on top of the hourly limits above, so per-user LLM
# spend during the beta is capped regardless of how the hourly limit is spent.
RATE_LIMIT_PREDICT_DAILY=20/day
RATE_LIMIT_BATCH_DAILY=10/day
# Hard cap on companies per /batch request, independent of how often the
# endpoint itself can be called.
MAX_BATCH_COMPANIES=10

# ── Celery Beat tuning ───────────────────────────────────────────────────────
# Hour (UTC) at which score_predictions_task fires daily
CELERY_SCORE_HOUR=6
CELERY_SCORE_MINUTE=0
# Days to wait after report_date before scoring (earnings need time to appear)
SCORE_AFTER_DAYS=1
# Worker concurrency (goroutine count per worker container)
CELERY_CONCURRENCY=2

# ── Error tracking (Sentry) ──────────────────────────────────────────────────
# Backend (api/worker/beat) — leave SENTRY_DSN unset to disable entirely (safe
# no-op locally). Get a DSN by creating a Python project at sentry.io.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development   # development | staging | production
SENTRY_TRACES_SAMPLE_RATE=0.1

# Frontend (web/) — separate Next.js project/DSN at sentry.io. Copy into
# web/.env.local for the Next.js dev server. Public: safe to expose client-side.
NEXT_PUBLIC_SENTRY_DSN=
