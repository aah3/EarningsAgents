# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy to .env and fill in real values before running Docker.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM API Keys ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ── Data sources ─────────────────────────────────────────────────────────────
NEWSAPI_API_KEY=your_newsapi_key_here
ALPHAVANTAGE_API_KEY=your_alphavantage_key_here

# ── Database (Supabase / Neon / RDS / local psql) ────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ── Redis (Upstash rediss:// or local redis://) ──────────────────────────────
REDIS_URL=rediss://default:token@host:6379?ssl_cert_reqs=none

# ── Clerk Auth ───────────────────────────────────────────────────────────────
CLERK_JWKS_URL=https://your-clerk-app.clerk.accounts.dev/.well-known/jwks.json
CLERK_API_URL=https://api.clerk.com
# Publishable key (safe to expose, injected at Next.js build time)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...

# ── Frontend URLs (injected at Next.js build time) ──────────────────────────
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
NEXT_PUBLIC_WS_URL=wss://api.yourdomain.com

# Also copy these into web/.env.local for the Next.js dev server:
# NEXT_PUBLIC_API_URL=http://localhost:8000
# NEXT_PUBLIC_WS_URL=ws://localhost:8000
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# ── CORS (backend) ───────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# In prod: set to your actual domain(s). In dev: http://localhost:3000 is the default.
CORS_ORIGINS=https://app.yourdomain.com,https://yourdomain.com

# ── Agent pipeline flags ─────────────────────────────────────────────────────
LLM_PROVIDER=gemini          # gemini | openai | anthropic | deepseek
USE_REACT=true
USE_REACT_MAX_TURNS=6
ENABLE_REBUTTALS=true

# ── Celery Beat tuning ───────────────────────────────────────────────────────
# Hour (UTC) at which score_predictions_task fires daily
CELERY_SCORE_HOUR=6
CELERY_SCORE_MINUTE=0
# Days to wait after report_date before scoring (earnings need time to appear)
SCORE_AFTER_DAYS=1
# Worker concurrency (goroutine count per worker container)
CELERY_CONCURRENCY=2
